# ═══════════════════════════════════════════════════════════════════════════════
# aira-relay — unified environment for all services
# docker-compose reads this file for both WAHA and the Python relay
# ═══════════════════════════════════════════════════════════════════════════════

# ── Security ────────────────────────────────────────────────────────────────
WAHA_API_KEY=6fa7784db809420eb95a3d22e02a5706
WAHA_DASHBOARD_USERNAME=admin
WAHA_DASHBOARD_PASSWORD=ed5400fb1e614165a4fa1cbcf72d904c
WHATSAPP_SWAGGER_USERNAME=admin
WHATSAPP_SWAGGER_PASSWORD=ed5400fb1e614165a4fa1cbcf72d904c

# Shared HMAC secret — WAHA signs webhook payloads; relay verifies them
WHATSAPP_HOOK_HMAC_KEY=super-secret-key
WAHA_WEBHOOK_SECRET=super-secret-key

# ── WAHA webhook ─────────────────────────────────────────────────────────────
# docker-compose overrides WHATSAPP_HOOK_URL to http://relay:8001/webhook/waha
# This value is used when running WAHA outside Docker (local dev):
WHATSAPP_HOOK_URL=http://localhost:8001/webhook/waha
WHATSAPP_HOOK_EVENTS=session.status,message,message.reaction

# ── WAHA general ─────────────────────────────────────────────────────────────
WAHA_DASHBOARD_ENABLED=True
WHATSAPP_SWAGGER_ENABLED=True

# Engine: GOWS (fastest) | NOWEB | WEBJS
WHATSAPP_DEFAULT_ENGINE=GOWS

# Public URL of the WAHA container (update if behind a reverse proxy)
WAHA_PUBLIC_URL=http://localhost:3002
WAHA_BASE_URL=http://localhost:3002

# Logging
WAHA_LOG_FORMAT=PRETTY
WAHA_LOG_LEVEL=info
WAHA_PRINT_QR=False

# ── WAHA media storage ────────────────────────────────────────────────────────
WAHA_MEDIA_STORAGE=LOCAL
WHATSAPP_FILES_LIFETIME=300
WHATSAPP_FILES_FOLDER=/app/.media

# ── MongoDB ───────────────────────────────────────────────────────────────────
# docker-compose overrides both *_MONGO_URL vars to use the mongodb container.
# These values apply when running services directly on the host (local dev):
WHATSAPP_SESSIONS_MONGO_URL=mongodb://localhost:27017
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=aira_relay

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Only needed for phonetic/embedding contact search (Qdrant).
# Not needed for MCP sampling — that goes through Claude Desktop.
OPENAI_API_KEY=sk-...

# ── Relay server ports ────────────────────────────────────────────────────────
MCP_PORT=8000
WEBHOOK_PORT=8001
